# Backend environment variables
# Database (local SQLite)
DATABASE_URL=sqlite+aiosqlite:///./rag.db

# Neo4j
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=test

# Vector Database (local ChromaDB)
VECTOR_DB_TYPE=chroma
VECTOR_DB_URL=./chroma_data

# Embedding API (online, OpenAI-compatible)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_API_BASE=https://api.openai.com/v1/embeddings
EMBEDDING_TIMEOUT_SECONDS=30

# Security
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Features
DEBUG=True
LOG_LEVEL=INFO
ENABLE_CACHE=True
CACHE_TTL_SECONDS=300
MAX_QUERY_LENGTH=5000

# API
HOST=0.0.0.0
PORT=8000

# LLM Configuration (online)
# Providers: deepseek, tongyi, openai
LLM_PROVIDER=deepseek
LLM_API_KEY=your-llm-api-key
# LLM_API_BASE=  # Optional, only if using custom endpoint
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
